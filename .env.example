# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_SERVICE_ACCOUNT_EMAIL: The email of your Google Service Account.
GOOGLE_SERVICE_ACCOUNT_EMAIL=""

# GOOGLE_PRIVATE_KEY: The private key of your Google Service Account. 
# Make sure to include the BEGIN/END PRIVATE KEY lines.
GOOGLE_PRIVATE_KEY=""

# GOOGLE_SHEET_ID: The ID of the Google Spreadsheet to connect to.
GOOGLE_SHEET_ID=""
